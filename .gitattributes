# Auto detect text files and normalize line endings to LF
* text=auto

# Explicitly declare text files you want to normalize
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.py text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Declare files that will always have LF line endings on checkout
.env.example text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.eot binary
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary
