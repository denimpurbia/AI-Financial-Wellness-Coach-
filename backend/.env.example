# 🚀 Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
# Generate a secure SECRET_KEY: python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=your_secret_key_here_generate_with_os_urandom

# 🖥️ Server Configuration
HOST=localhost
PORT=5000

# 🔐 Supabase Configuration
# Get these from: https://app.supabase.com
# 1. Go to Settings > API
# 2. Copy Project URL and Anon Key / Service Role Key
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_key_here

# 🤖 OpenRouter Configuration
# Get your API key from: https://openrouter.ai/login
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_APP_TITLE=AI Financial Wellness Coach

# 🎨 AI Model Configuration
AI_MODEL=~openai/gpt-latest
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# 🌐 CORS Configuration
# Add your frontend URLs here (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# 💾 Database Configuration
DATABASE_SCHEMA=public
